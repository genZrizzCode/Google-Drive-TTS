{
  "manifest_version": 3,
  "name": "Drive PDF Reader",
  "version": "1.1.0",
  "description": "Read PDF text from Google Drive aloud.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "tabs", "tts", "scripting"],
  "host_permissions": [
    "https://drive.google.com/*",
    "https://docs.google.com/*",
    "https://*.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Drive PDF Reader",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
