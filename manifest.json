{
  "manifest_version": 3,
  "name": "Drive PDF Reader",
  "version": "1.0.0",
  "description": "Read PDF text from Google Drive aloud.",
  "permissions": ["activeTab", "tabs", "tts"],
  "host_permissions": [
    "https://drive.google.com/*",
    "https://docs.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Drive PDF Reader",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://drive.google.com/*",
        "https://docs.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
